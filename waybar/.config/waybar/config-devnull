[
  {
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 8,

    "modules-left": [
      "hyprland/workspaces",
      "hyprland/window"
    ],

    "modules-right": [
      "disk#root",
      "pulseaudio",
      "backlight",
      "memory",
      "cpu",
      "battery",
      "network",
      "hyprland/language",
      "tray",
      "clock"
    ],

    "hyprland/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "sort-by-number": true,
      "persistent-workspaces": true
    },

    "hyprland/window": {
      "format": "{title:.80}",
      "separate-outputs": true
    },

    "disk#root": {
      "interval": 30,
      "path": "/",
      "format": "Root {percentage_used}%"
    },

    "pulseaudio": {
      "format": "VOL {volume}%",
      "format-muted": "VOL muted",
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },

    "backlight": {
      "format": "BRI {percent}%",
      "on-scroll-up": "brightnessctl set 5%+",
      "on-scroll-down": "brightnessctl set 5%-"
    },

    "memory": {
      "interval": 2,
      "format": "RAM {percentage:2d}%"
    },

    "cpu": {
      "interval": 2,
      "format": "CPU {usage:2d}%"
    },

    "battery": {
      "interval": 10,
      "states": {
        "warning": 20,
        "critical": 10
      },
      "format": "BAT {capacity}%",
      "format-charging": "BAT {capacity}% (+)",
      "format-discharging": "BAT {capacity}% (-)",
      "format-full": "BAT {capacity}% (=)",
      "tooltip": true
    },

    "network": {
      "interval": 5,
      "format-wifi": "{ifname} {essid} {ipaddr}",
      "format-ethernet": "{ifname} {ipaddr}",
      "format-disconnected": "net off",
      "tooltip": true
    },

    "hyprland/language": {
      "format": "{short}"
    },

    "tray": {
      "spacing": 10
    },

    "clock": {
      "interval": 1,
      "format": "{:%a %d/%m %H:%M}",
      "tooltip": false
    }
  },

  {
    "layer": "top",
    "position": "bottom",
    "height": 24,
    "spacing": 10,

    "modules-left": [
      "custom/wg",
      "custom/pi",
      "custom/desk"
    ],
    "modules-center": [
      "custom/nowplaying"
    ],
    "modules-right": [
      "custom/bt"
    ],

    "custom/wg": {
      "interval": 2,
      "exec": "bash -lc \"$HOME/.config/polybar/scripts/wg-status.sh wg-home\"",
      "return-type": "text"
    },

    "custom/pi": {
      "interval": 5,
      "exec": "bash -lc \"$HOME/.config/polybar/scripts/port-status.sh PI 10.10.0.1 22 2\"",
      "return-type": "text"
    },

    "custom/desk": {
      "interval": 5,
      "exec": "bash -lc \"$HOME/.config/polybar/scripts/port-status.sh DESK 10.10.0.1 2222 2\"",
      "return-type": "text"
    },

    "custom/nowplaying": {
      "interval": 1,
      "exec": "bash -lc \"$HOME/.config/polybar/scripts/now-playing.sh\"",
      "return-type": "text"
    },

    "custom/bt": {
      "interval": 3,
      "exec": "bash -lc \"$HOME/.config/polybar/scripts/bt-status.sh\"",
      "return-type": "text"
    }
  }
]
